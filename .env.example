# Azure AI Foundry Configuration
# To enable the chat feature, copy this file to .env and fill in your Azure AI Foundry credentials

# Azure AI Project Connection String
# Get this from your Azure AI Foundry project settings
AZURE_AI_PROJECT_CONNECTION_STRING=

# Azure AI Agent Name
# The name of your deployed agent in Azure AI Foundry
AZURE_AI_AGENT_NAME=DroneOps Copilot
